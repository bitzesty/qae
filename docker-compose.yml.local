version: "2"
services:
  web: &web
    build:
      context: .
    command: bundle exec puma -C config/puma.rb
    env_file:
      - .env.example
    ports:
      - 80:3000/tcp
      - 443:3000/tcp
    links:
      - database
      - redis
  worker:
    <<: *web
    ports: []
    build:
      context: .
    command: bundle exec sidekiq -C config/sidekiq.yml
  redis:
    image: convox/redis
    ports:
      - 6379
  database:
    image: convox/postgres
    ports:
      - 5432
